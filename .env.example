# ---- LLM provider ----------------------------------------------------------
# Default provider is Anthropic Claude. Set your key to enable real generation.
# Without a key the app falls back to the "echo" provider (useful for CI/tests).
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Most capable model by default; swap to claude-haiku-4-5 to cut cost.
LLM_MODEL=claude-opus-4-8
LLM_EFFORT=medium
LLM_MAX_TOKENS=1024

# ---- Embeddings ------------------------------------------------------------
# Open model, no per-call cost. Set EMBEDDINGS_PROVIDER=hash for an offline,
# dependency-free fallback (used automatically in CI).
EMBEDDINGS_PROVIDER=sentence-transformers
EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5

# ---- Vector store ----------------------------------------------------------
# pgvector (Postgres) in production; "memory" (numpy) for local dev / CI.
VECTOR_STORE=pgvector
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# ---- Retrieval -------------------------------------------------------------
TOP_K=5
CHUNK_TOKENS=600
CHUNK_OVERLAP=80
MIN_RETRIEVAL_SCORE=0.25

# ---- Guardrails ------------------------------------------------------------
INJECTION_SCORE_THRESHOLD=0.8
GROUNDING_MIN_SUPPORT=0.35

# ---- API -------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=30
CORS_ALLOW_ORIGINS=*
